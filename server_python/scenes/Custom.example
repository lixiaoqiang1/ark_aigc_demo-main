{
  "SceneConfig": {
    "icon": "https://lf3-rtc-demo.volccdn.com/obj/rtc-aigc-assets/DoubaoAvatar.png",
    "name": "自定义助手"
  },
  "AccountConfig": {
    "accessKeyId": "YOUR_ACCESS_KEY_ID",
    "secretKey": "YOUR_SECRET_KEY"
  },
  "RTCConfig": {
    "AppId": "YOUR_RTC_APP_ID",
    "AppKey": "YOUR_RTC_APP_KEY",
    "RoomId": "",
    "UserId": "",
    "Token": ""
  },
  "VoiceChat": {
    "AppId": "YOUR_RTC_APP_ID",
    "RoomId": "",
    "TaskId": "ChatTask01",
    "AgentConfig": {
      "TargetUserId": [
        ""
      ],
      "WelcomeMessage": "你好，我是AI助理，有什么需要帮忙的吗？",
      "UserId": "ChatBot01",
      "EnableConversationStateCallback": true
    },
    "Config": {
      "ASRConfig": {
        "Provider": "volcano",
        "ProviderParams": {
          "Mode": "smallmodel",
          "AppId": "YOUR_SPEECH_APP_ID",
          "Cluster": "volcengine_streaming_common"
        }
      },
      "TTSConfig": {
        "Provider": "volcano",
        "ProviderParams": {
          "app": {
            "appid": "YOUR_SPEECH_APP_ID",
            "cluster": "volcano_tts"
          },
          "audio": {
            "voice_type": "BV001_streaming",
            "speed_ratio": 1,
            "pitch_ratio": 1,
            "volume_ratio": 1
          }
        }
      },
      "LLMConfig": {
        "Mode": "ArkV3",
        "EndPointId": "YOUR_ARK_ENDPOINT_ID",
        "ApiKey": "YOUR_ARK_API_KEY",
        "SystemMessages": [
          "你是小宁，性格幽默又善解人意。你在表达时需简明扼要，有自己的观点。"
        ],
        "VisionConfig": {
          "Enable": false
        }
      },
      "AvatarConfig": {
        "Enabled": false,
        "AvatarType": "3min",
        "AvatarRole": "YOUR_AVATAR_ROLE",
        "BackgroundUrl": "",
        "VideoBitrate": 2000,
        "AvatarAppID": "",
        "AvatarToken": ""
      },
      "InterruptMode": 0
    }
  }
}
