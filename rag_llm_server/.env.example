# =====================================================================
# rag_llm_server 环境变量配置模板
# 适用场景：CustomLLM + RAG 知识库模式（与默认 Server/scenes 方案不同）
#
# 使用方法：复制本文件为 .env，并填入真实凭证
#   PowerShell:  Copy-Item .env.example .env
#   CMD:         copy .env.example .env
# =====================================================================

# ---------------------------------------------------------------------
# VOLC_ACCESS_KEY
# 说明：火山引擎 Access Key ID，用于 HMAC 签名调用 RTC OpenAPI、知识库检索等
# 格式：以 AKLT 开头的字符串
# 获取：https://console.volcengine.com/iam/keymanage/
# 对应 Custom.json：AccountConfig.accessKeyId
# ---------------------------------------------------------------------
VOLC_ACCESS_KEY=your_access_key_here

# ---------------------------------------------------------------------
# VOLC_SECRET_KEY
# 说明：与 Access Key 配对的 Secret Key，仅保存在服务端，切勿提交 Git
# 格式：Base64 编码字符串
# 获取：https://console.volcengine.com/iam/keymanage/（与 AK 同时创建）
# 对应 Custom.json：AccountConfig.secretKey
# ---------------------------------------------------------------------
VOLC_SECRET_KEY=your_secret_key_here

# ---------------------------------------------------------------------
# VOLC_ACCOUNT_ID
# 说明：火山引擎主账号 ID，知识库检索 API 请求头 V-Account-Id 必填
# 格式：kb- 开头的字符串
# 获取：https://console.volcengine.com/ark/region:ark+cn-beijing/knowledge（知识库控制台右上角账号信息）
# 用途：services/rag_service.py 检索知识库
# ---------------------------------------------------------------------
VOLC_ACCOUNT_ID=kb-xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# ARK_API_KEY
# 说明：方舟（Ark / 豆包）API Key，用于调用大模型生成回复
# 格式：字符串
# 获取：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 用途：services/llm_service.py 流式调用大模型
# ---------------------------------------------------------------------
ARK_API_KEY=your_ark_api_key_here

# ---------------------------------------------------------------------
# ARK_ENDPOINT_ID
# 说明：方舟模型接入点 ID，指定使用哪个大模型（如豆包系列）
# 格式：ep- 开头，如 ep-20260705151434-g76hf
# 获取：https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint（创建接入点）
# 对应 Custom.json：VoiceChat.Config.LLMConfig.EndPointId
# ---------------------------------------------------------------------
ARK_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# ASR_TTS_APP_ID
# 说明：语音识别（ASR）与语音合成（TTS）的应用 ID，与 RTC AppId 不是同一个
# 格式：纯数字
# 获取：https://console.volcengine.com/speech/service/app
#       创建应用后勾选「流式语音识别」和「语音合成」，复制 AppId
# 对应 Custom.json：ASRConfig.ProviderParams.AppId、TTSConfig.ProviderParams.app.appid
# 注意：当前 main.py 部分逻辑仍硬编码，填好后需同步改代码或后续接入本变量
# ---------------------------------------------------------------------
ASR_TTS_APP_ID=your_speech_app_id_here

# ---------------------------------------------------------------------
# RTC_APP_ID
# 说明：RTC 实时音视频应用 ID，用户与 AI 在同一房间通话
# 格式：24 位十六进制字符串
# 获取：https://console.volcengine.com/rtc/aigc/listRTC
# 对应 Custom.json：RTCConfig.AppId、VoiceChat.AppId
# ---------------------------------------------------------------------
RTC_APP_ID=your_rtc_app_id

# ---------------------------------------------------------------------
# RTC_APP_KEY
# 说明：RTC 应用密钥，用于服务端生成进房 Token，不可暴露给前端
# 格式：32 位十六进制字符串，须与 RTC_APP_ID 配对
# 获取：https://console.volcengine.com/rtc/aigc/listRTC（与应用 AppId 同页）
# 对应 Custom.json：RTCConfig.AppKey
# ---------------------------------------------------------------------
RTC_APP_KEY=your_rtc_app_key

# ---------------------------------------------------------------------
# SERVER_URL
# 说明：本服务的外网可访问地址。火山 RTC 云端在 CustomLLM 模式下会回调此地址获取 LLM 回复
# 格式：http(s)://域名或IP:端口（生产环境建议 https）
# 本地调试：需内网穿透（ngrok / cpolar / frp）获取公网地址，127.0.0.1 云端无法回调
# 用途：StartVoiceChat 中 LLMConfig.Url = {SERVER_URL}/api/chat_callback
# ---------------------------------------------------------------------
SERVER_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------
# KB_COLLECTION_NAME（可选）
# 说明：知识库集合名称，RAG 检索时指定从哪个知识库取资料
# 格式：字符串，默认 dw_ai
# 获取：https://console.volcengine.com/ark/region:ark+cn-beijing/knowledge（创建知识库后查看）
# 用途：services/rag_service.py
# ---------------------------------------------------------------------
KB_COLLECTION_NAME=dw_ai

# ---------------------------------------------------------------------
# KB_PROJECT_NAME（可选）
# 说明：知识库所属项目名称
# 格式：字符串，默认 default
# 获取：同上知识库控制台
# 用途：services/rag_service.py
# ---------------------------------------------------------------------
KB_PROJECT_NAME=default
