# =====================================================================
# rag_llm_server 环境变量配置模板
# 使用方法：复制本文件为 .env，并填入真实凭证
#   PowerShell:  Copy-Item .env.example .env
#   CMD:         copy .env.example .env
# =====================================================================

# ---- 火山引擎账号签名密钥（用于签名调用 RTC / 知识库 OpenAPI）----
# 获取地址：https://console.volcengine.com/iam/keymanage/
VOLC_ACCESS_KEY=your_access_key_here
VOLC_SECRET_KEY=your_secret_key_here

# ---- 火山引擎主账号 ID（知识库检索接口的 V-Account-Id 必填）----
VOLC_ACCOUNT_ID=kb-xxxxxxxxxxxxxxxx

# ---- 方舟（Ark / 豆包）大模型配置 ----
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/overview
ARK_API_KEY=your_ark_api_key_here
ARK_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx

# ---- 语音识别 / 语音合成 AppId（AIGC 对话必填，与 RTC AppId 不是同一个）----
# 获取地址：https://console.volcengine.com/speech/service/app
# 创建应用后勾选「流式语音识别」和「语音合成」，复制 AppId（纯数字）
ASR_TTS_APP_ID=your_speech_app_id_here

# 获取地址：https://console.volcengine.com/rtc/aigc/listRTC
RTC_APP_ID=your_rtc_app_id
RTC_APP_KEY=your_rtc_app_key

# ---- 本服务的外网可访问地址（火山 RTC 云端回调 LLM 时必须能访问到这个地址）----
# 本地调试可用内网穿透（如 ngrok / cpolar / frp）获取 https 公网地址
# 必须是公网可达地址，否则 StartVoiceChat 的 CustomLLM 回调会失败
SERVER_URL=http://127.0.0.1:8000

# ---- 知识库配置（可选，未配置则走默认值）----
KB_COLLECTION_NAME=dw_ai
KB_PROJECT_NAME=default
